PORT=8080
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-service-account-private-key\n-----END PRIVATE KEY-----\n"

# Public Firebase Web SDK config for frontend signup/sign-in.
# Copy these from Firebase Console > Project settings > General > Your apps > Web app.
FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key
FIREBASE_WEB_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
FIREBASE_WEB_APP_ID=replace-with-firebase-web-app-id
FIREBASE_WEB_MESSAGING_SENDER_ID=replace-with-sender-id
FIREBASE_WEB_STORAGE_BUCKET=your-firebase-project-id.appspot.com
FIREBASE_WEB_MEASUREMENT_ID=replace-with-measurement-id
